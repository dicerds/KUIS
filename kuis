const state = { q02: {}, q03: {} };

function buildQuiz(id, data) {
  const wrap = document.getElementById(`${id}-questions`);
  wrap.innerHTML = '';
  state[id] = {};

  data.forEach((item, i) => {
    const labels = ['A','B','C','D','E'];
    const optBtns = item.opts.map((opt, j) => `
      <button class="option-btn" onclick="answer('${id}',${i},${j})" id="${id}-q${i}-o${j}">
        <span class="option-label">${labels[j]}</span>
        ${opt}
      </button>
    `).join('');

    wrap.innerHTML += `
      <div class="q-card" id="${id}-q${i}">
        <div class="q-header">
          <div class="q-num">${String(i+1).padStart(2,'0')}</div>
          <div class="q-text">${item.q}</div>
          <div class="status-icon" id="${id}-q${i}-icon"></div>
        </div>
        <div class="options">${optBtns}</div>
        <div class="explanation" id="${id}-q${i}-exp">
          <div class="explanation-title">💡 Penjelasan</div>
          <div class="explanation-text">${item.exp}</div>
        </div>
      </div>
    `;
  });

  updateScore(id);
}

function answer(id, qIdx, optIdx) {
  if (state[id][qIdx] !== undefined) return;
  state[id][qIdx] = optIdx;

  const data = id === 'q02' ? Q02 : Q03;
  const correct = data[qIdx].ans;
  const card = document.getElementById(`${id}-q${qIdx}`);
  const icon = document.getElementById(`${id}-q${qIdx}-icon`);
  const exp = document.getElementById(`${id}-q${qIdx}-exp`);
  const opts = card.querySelectorAll('.option-btn');

  opts.forEach(btn => btn.disabled = true);

  if (optIdx === correct) {
    opts[optIdx].classList.add('correct');
    card.classList.add('answered-correct');
    icon.textContent = '✓';
    icon.style.color = 'var(--green)';
  } else {
    opts[optIdx].classList.add('wrong');
    opts[correct].classList.add('show-correct');
    card.classList.add('answered-wrong');
    icon.textContent = '✗';
    icon.style.color = 'var(--red)';
  }

  exp.classList.add('show');
  updateScore(id);
}

function updateScore(id) {
  const data = id === 'q02' ? Q02 : Q03;
  const total = data.length;
  let correct = 0, wrong = 0;

  Object.keys(state[id]).forEach(k => {
    if (state[id][k] === data[k].ans) correct++;
    else wrong++;
  });

  const answered = Object.keys(state[id]).length;
  const remain = total - answered;

  document.getElementById(`${id}-correct`).textContent = correct;
  document.getElementById(`${id}-wrong`).textContent = wrong;
  document.getElementById(`${id}-remain`).textContent = remain;
  document.getElementById(`${id}-prog`).style.width = `${(answered/total)*100}%`;
  document.getElementById(`${id}-prog-text`).textContent = `${answered} / ${total} dijawab`;
}

function resetQuiz(id) {
  const data = id === 'q02' ? Q02 : Q03;
  buildQuiz(id, data);
}

function buildCheat(id, data) {
  const grid = document.getElementById(`${id}-cheat-grid`);
  const labels = ['A','B','C','D','E'];
  grid.innerHTML = data.map((item, i) => `
    <div class="cheat-item">
      <div class="cheat-q"><strong>${i+1}.</strong> ${item.q.length > 100 ? item.q.substring(0,97)+'...' : item.q}</div>
      <div class="cheat-a">${labels[item.ans]}. ${item.opts[item.ans]}</div>
    </div>
  `).join('');
}

function switchQuiz(id) {
  document.querySelectorAll('.quiz-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  event.target.classList.add('active');
}

function switchInner(quizId, panel) {
  const section = document.getElementById(quizId);
  section.querySelectorAll('.inner-panel').forEach(p => p.classList.remove('active'));
  section.querySelectorAll('.inner-tab').forEach(t => t.classList.remove('active'));
  document.getElementById(`${quizId}-${panel}`).classList.add('active');
  event.target.classList.add('active');
}

// INIT
buildQuiz('q02', Q02);
buildQuiz('q03', Q03);
buildCheat('q02', Q02);
buildCheat('q03', Q03);
</script>
